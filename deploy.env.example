# Copy to deploy.env and adjust for your server.
# cp deploy.env.example deploy.env

# Skip git pull (useful when you already pulled manually)
# SKIP_GIT_PULL=false

# Use npm install instead of npm ci (slower but avoids lockfile sync issues)
# USE_NPM_INSTALL=false

# Backend process manager (use one)
PM2_APP_NAME=chaptergen-api
# SYSTEMD_SERVICE=chaptergen-api

# Where nginx (or another web server) serves the static frontend
FRONTEND_WEB_ROOT=/var/www/chaptergen

# Reload nginx after publishing the frontend
NGINX_RELOAD=true

# Env files: .env, .env.production, or .env.production.local in backend/ and frontend/
# Vite loads .env.production automatically during build; no .env symlink needed.
