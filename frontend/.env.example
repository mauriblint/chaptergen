# Site URL used for canonical links, OG tags, and hreflang
VITE_SITE_URL=https://chaptergen.com

# API base URL (defaults to /api for dev proxy)
VITE_API_BASE=/api

# Chunk size for file uploads in MB (keep under Cloudflare 100MB limit)
VITE_UPLOAD_CHUNK_SIZE_MB=20

# Max retry attempts per chunk on upload failure
VITE_UPLOAD_MAX_RETRIES=3
