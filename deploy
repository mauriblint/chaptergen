#!/usr/bin/env bash
set -e

cd "$(dirname "$0")"

BRANCH=main

echo "==> sync con origin/$BRANCH (descartando cambios locales)"
git fetch origin
git checkout "$BRANCH"
git reset --hard "origin/$BRANCH"
git clean -fd

echo "==> backend build"
npm ci --prefix backend
npm run build --prefix backend

echo "==> restart backend (pm2)"
pm2 restart chaptergen-api

echo "==> frontend build"
npm ci --prefix frontend
npm run build --prefix frontend

echo "==> done"
echo "backend build: backend/dist"
echo "frontend build: frontend/dist"
