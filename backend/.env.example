# OpenAI API key (required)
OPENAI_API_KEY=sk-your-key-here

# Server port
PORT=3006

# Max upload size in MB
MAX_FILE_SIZE_MB=500

# Max chunk size in MB (individual chunk uploads)
CHUNK_MAX_SIZE_MB=50

# Hours before abandoned upload sessions are deleted
UPLOAD_SESSION_TTL_HOURS=24

# SQLite database path (optional, default: data/chaptergen.db)
# DATABASE_PATH=data/chaptergen.db

# Admin panel auth
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=random-long-string
